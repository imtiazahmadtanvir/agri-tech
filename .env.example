# -----------------------------------------------------------------------------
# 🌱 AgriTech - Environment Variables Template (.env.example)
# Copy this file to '.env.local' and populate with your own credentials.
# -----------------------------------------------------------------------------

# 💾 Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DBNAME=agri-tech

# 🌐 Application Base URLs
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 🔒 Authentication & Security Configuration
# Generate a secret key (e.g., using: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_jwt_secret_key_here

# 🔑 OAuth Providers Credentials
# Google OAuth (For user login)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth (For user login)
GITHUB_ID=your_github_client_id_here
GITHUB_SECRET=your_github_client_secret_here

# 🌦️ Weather API Integrations
# Sign up at https://openweathermap.org/ to get a free key
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# 🤖 Gemini AI (Google Generative AI SDK)
# Obtain an API key from Google AI Studio: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_gemini_server_api_key_here
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_gemini_client_api_key_here

# 💳 Payment Gateways Configuration
# SSLCommerz Sandbox Credentials
SSLCOMMERZ_STORE_ID=your_sslcommerz_store_id_here
SSLCOMMERZ_STORE_PASSWORD=your_sslcommerz_store_password_here

